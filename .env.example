# Wallet (never commit real keys)
PRIVATE_KEY=0xyour_private_key_here

# Robinhood Chain RPC (WSS strongly recommended for low latency)
RPC_URL=https://rpc.mainnet.chain.robinhood.com
WSS_RPC_URL=

# Safety: keep true until you are ready to spend real ETH
DRY_RUN=true

# Buy size in native ETH (wrapped to WETH for the swap)
BUY_AMOUNT_ETH=0.01

# Exit rules (percent relative to entry)
TAKE_PROFIT_PERCENT=50
# Set > 0 to enable, e.g. 30 = sell if down 30%
STOP_LOSS_PERCENT=0

# Slippage in basis points (500 = 5%)
SLIPPAGE_BPS=500

# Filters
MIN_INITIAL_BUY_ETH=0
MAX_OPEN_POSITIONS=3
# Comma-separated substrings; matching name/symbol is skipped (case-insensitive)
DENY_NAME_SUBSTRINGS=test,scam,honeypot

# Price poll interval for open positions (ms)
POLL_MS=2000
